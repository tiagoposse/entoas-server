{{- define "update" -}}
// Update{{ .Node.Name }} updates an existing {{ .Node.Name }}.
func (h *EntHandler) Update{{ .Node.Name }}(ctx context.Context, request Update{{ .Node.Name }}RequestObject) (Update{{ .Node.Name }}ResponseObject, error) {
{{ if .GuardCode }}
{{ .GuardCode }}
{{ end }}
	if custom{{ .Node.Name }}Update != nil {
		return custom{{ .Node.Name }}Update(ctx, h.client, request)
	}

	builder := h.client.{{ .Node.Name }}.UpdateOneID(request.Id)
{{- if .PatchSemantics }}

	// Patch semantics: detect explicit nulls by re-marshaling the body
	_rawBody, _ := json.Marshal(request.Body)
	var _rawFields map[string]json.RawMessage
	json.Unmarshal(_rawBody, &_rawFields)
{{- end }}

	// Set fields from request
	{{- range $f := .Node.Fields }}
	{{- $fieldName := lower $f.Name }}
	{{- if and (not $f.Immutable) (not (isReadOnly $f)) (not (isSensitive $f)) (ne $fieldName "id") (ne $fieldName "created_at") (ne $fieldName "updated_at") }}
	{{- $apiFieldName := oapiFieldName $f.StructField }}
	{{- if and $.PatchSemantics $f.Optional $f.Nillable }}
	// Patch semantics for {{ $f.Name }}: distinguish absent vs explicit null
	if _raw, _exists := _rawFields["{{ $f.Name }}"]; _exists {
		if string(_raw) == "null" {
			builder.Clear{{ $f.StructField }}()
		} else if request.Body.{{ $apiFieldName }} != nil {
			{{- if isUUID $f }}
			builder.Set{{ $f.StructField }}(uuid.UUID(*request.Body.{{ $apiFieldName }}))
			{{- else if isEnum $f }}
			builder.Set{{ $f.StructField }}({{ lower $.Node.Name }}.{{ $apiFieldName }}(string(*request.Body.{{ $apiFieldName }})))
			{{- else }}
			builder.Set{{ $f.StructField }}(*request.Body.{{ $apiFieldName }})
			{{- end }}
		}
	}
	{{- else }}
	if request.Body.{{ $apiFieldName }} != nil {
		{{- if isUUID $f }}
		builder.Set{{ $f.StructField }}(uuid.UUID(*request.Body.{{ $apiFieldName }}))
		{{- else if isEnum $f }}
		builder.Set{{ $f.StructField }}({{ lower $.Node.Name }}.{{ $apiFieldName }}(string(*request.Body.{{ $apiFieldName }})))
		{{- else if isSlice $f }}
		builder.Set{{ $f.StructField }}(*request.Body.{{ $apiFieldName }})
		{{- else }}
		builder.Set{{ $f.StructField }}(*request.Body.{{ $apiFieldName }})
		{{- end }}
	}
	{{- end }}
	{{- end }}
	{{- end }}

	// Call before hook if defined
	if before{{ .Node.Name }}Update != nil {
		if err := before{{ .Node.Name }}Update(ctx, h.client, builder); err != nil {
			return nil, err
		}
	}

	entity, err := builder.Save(ctx)
	if err != nil {
		if ent.IsNotFound(err) {
			return Update{{ .Node.Name }}404JSONResponse{}, nil
		}
		return nil, err
	}

	// Call after hook if defined
	if after{{ .Node.Name }}Update != nil {
		if err := after{{ .Node.Name }}Update(ctx, h.client, entity); err != nil {
			return nil, err
		}
	}
{{ if .AfterHookCode }}
{{ .AfterHookCode }}
{{ end }}
	result := entTo{{ .Node.Name }}[{{ .Node.Name }}](entity)
	return Update{{ .Node.Name }}200JSONResponse(result), nil
}
{{- end -}}
